# Copy this file to .env or .env.local for local development.
# Never commit real API keys, bridge tokens, uploaded materials, or secret files.

HOST=127.0.0.1
PORT=8787
DATA_DIR=./data
SECRETS_DIR=./data/secrets
SANDBOX_MODE=auto
SANDBOX_IMAGE=python:3.13-slim
PATROL_RUNNER=local
PI_AGENT_RUNNER=
PI_AGENT_ALLOW_BUILTIN_TOOLS=false
PATROL_BRIDGE_TOKEN=replace-with-local-random-token

# LLM provider selection: mock, kimi, openai, or openrouter.
# Use mock for local chain testing without a network provider.
LLM_PROVIDER=mock
LLM_REQUIRED=false

# OpenAI Responses API.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Kimi For Coding via Pi CLI.
KIMI_API_KEY=
KIMI_MODEL=kimi-for-coding
KIMI_THINKING=off
KIMI_PLANNING_TIMEOUT_MS=90000

# OpenRouter. Keep the API key only in .env.local or data/secrets/openrouter.env, never in tracked files.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8787
OPENROUTER_APP_NAME=patrol-stand-agent-local
